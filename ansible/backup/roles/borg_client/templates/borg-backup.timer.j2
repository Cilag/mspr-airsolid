[Unit]
Description=Timer — Sauvegarde BorgBackup quotidienne ({{ inventory_hostname }})

[Timer]
# Sauvegarde à 23h00, avec randomisation de 30min pour éviter la congestion
OnCalendar=*-*-* {{ borg_backup_hour }}:{{ borg_backup_minute }}:00
RandomizedDelaySec=1800
Persistent=true

[Install]
WantedBy=timers.target
