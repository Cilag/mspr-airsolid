# Copier ce fichier en terraform.tfvars et renseigner les valeurs
# NE JAMAIS commiter terraform.tfvars (contient des secrets)

proxmox_endpoint     = "https://192.168.1.100:8006/"
proxmox_token_id     = "terraform@pve!mytoken"
proxmox_token_secret = "VOTRE_SECRET_ICI"
proxmox_node         = "pve"
airsolid_storage     = "local-lvm"

